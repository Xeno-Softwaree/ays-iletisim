generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  fullName      String?
  password      String?
  phone         String?
  isAdmin       Boolean   @default(false)
  emailVerified DateTime?
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  resetPasswordTokenHash    String?
  resetPasswordTokenExpires DateTime?

  cart          Cart?
  orders        Order[]
  addresses     Address[]
  favorites     Favorite[]
  reviews       Review[]
  tradeInRequests TradeInRequest[]
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  title       String   // e.g. "Ev", "İş"
  fullName    String
  phone       String
  city        String
  district    String
  openAddress String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id        String   @id @default(uuid())
  email     String
  token     String
  expiresAt DateTime

  @@unique([email, token])
}

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  image       String?
  parentId    String?
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  brands      Brand[]

  @@index([slug])
}

model Product {
  id              String           @id @default(uuid())
  name            String
  slug            String           @unique
  description     String
  price           Decimal
  stock           Int              @default(0)
  images          String[]
  colors          Json?            // e.g. [{"name":"Siyah","hex":"#1a1a1a"}]
  categoryId      String
  brandId         String?
  batteryHealth   Int?             // Battery health percentage (0-100)
  warrantyStatus  String?          // e.g., "6 Ay Garanti", "Garantisiz", "1 Yıl Garanti"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  condition       ProductCondition @default(NEW)
  compareAtPrice  Decimal?         // Original price before discount
  isFeatured      Boolean          @default(false)
  cartItems       CartItem[]
  orderItems      OrderItem[]
  brand           Brand?           @relation(fields: [brandId], references: [id])
  category        Category         @relation(fields: [categoryId], references: [id])
  favoritedBy     Favorite[]
  reviews         Review[]
  stockAlerts     StockAlert[]

  @@index([slug])
  @@index([categoryId])
  @@index([brandId])
}


model Order {
  id          String      @id @default(uuid())
  userId      String?
  guestEmail  String?
  fullName    String?     // For shipping
  address     String?     // Full address
  city        String?
  phone       String?
  paymentMethod String?   // "CREDIT_CARD", "TRANSFER"
  trackingNumber String?  // Shipping tracking number
  status      OrderStatus @default(PENDING)
  totalAmount Decimal
  couponCode  String?
  discountAmount     Decimal     @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  
  // Legal consents
  distanceSalesAccepted      Boolean   @default(false)
  preInfoAccepted            Boolean   @default(false)
  kvkkRead                   Boolean   @default(false)
  contractsAcceptedAt        DateTime?
  contractsAcceptedIp        String?
  contractsAcceptedUserAgent String?

  user        User?       @relation(fields: [userId], references: [id])
  items       OrderItem[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal
  order     Order   @relation(fields: [orderId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model Brand {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  categories Category[]

  @@index([slug])
}

model TradeInRequest {
  id              String   @id @default(uuid())
  brand           String
  model           String
  screenCondition String   // "Temiz", "Çizik", "Kırık"
  batteryHealth   Int      // 0-100
  estimatedPrice  Decimal
  finalOffer      Decimal?
  adminNote       String?
  customerPhone   String
  customerName    String?
  customerEmail   String?
  status          String   @default("Beklemede") // "Beklemede", "İnceleniyor", "Onaylandı", "Reddedildi"
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id                  String   @id @default(uuid())
  whatsappNumber      String   @default("+905551234567")
  defaultMessage      String   @default("Merhaba, {productName} hakkında bilgi almak istiyorum.")
  baseDiscountRate    Float    @default(0.2) // Master discount rate
  conditionMultipliers Json?    // Multipliers for different conditions (e.g. {"Temiz": 1.0, "Çizik": 0.9, "Kırık": 0.7})
  tradeInModels       Json?    // Dynamic models and their base prices: [{brand, name, basePrice}]
  
  // Footer & Social Media
  instagramUrl        String?  @default("https://instagram.com")
  twitterUrl          String?  @default("https://twitter.com")
  facebookUrl         String?  @default("https://facebook.com")
  footerAbout         String?  @default("Sıfır ve ikinci el telefon, aksesuar ve teknolojik ürünlerde güvenilir adresiniz. Eskiyi getir, yeniyi al fırsatlarıyla teknolojiyi yakalayın.")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model DynamicPage {
  id        String   @id @default(uuid())
  slug      String   @unique // e.g., "sss", "gizlilik", "iade-kosullari", "kullanim-kosullari", "kvkk"
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

enum ProductCondition {
  NEW
  USED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Showcase {
  id          String   @id @default(uuid())
  title       String
  description String?
  imageUrl    String
  linkUrl     String?
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BankAccount {
  id            String   @id @default(uuid())
  bankName      String
  accountHolder String
  iban          String
  branchCode    String?
  accountNumber String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  productId String
  rating    Int
  comment   String?
  isApproved Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discountType String // "PERCENTAGE" | "FIXED"
  discountValue Decimal
  minOrderAmount Decimal?
  expirationDate DateTime?
  usageLimit  Int?
  usedCount   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInfo {
  id          String   @id @default(uuid())
  address     String   @default("Ordu Caddesi No:12/B\nMerkez, Erzincan")
  phone       String   @default("+90 555 123 45 67")
  email       String   @default("info@aysiletisim.com")
  mapEmbedUrl String   @default("https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3056.666993685655!2d39.4895!3d39.7500!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMznCsDQ1JzAwLjAiTiAzOcKwMjknMjIuMiJF!5e0!3m2!1str!2str!4v1635789000000!5m2!1str!2str")
  updatedAt   DateTime @updatedAt
}

model StockAlert {
  id        String   @id @default(uuid())
  email     String
  productId String
  isNotified Boolean @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([email, productId])
}
